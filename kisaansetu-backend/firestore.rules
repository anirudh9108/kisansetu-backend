rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Farmer profile and subcollections
    match /farmers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /irrigationLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /diseaseAlerts/{alertId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Public/Read-Only Collections for Authenticated Users
    // Only the backend (service account) can write to these
    match /schemes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
    match /mandiPrices/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
    match /cropRecommendations/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
    match /agriStores/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  }
}
